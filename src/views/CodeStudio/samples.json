{
  "html": "<div class=\"container\"><h1>欢迎使用样式调制工具</h1><p>在这里您可以编写和实时预览HTML/CSS/JS代码。</p><div class=\"demo-box\"><h2>演示盒子</h2><p>这是动态预览区域</p></div></div><style>.container { padding: 20px; background-color: #f5f5f5; border-radius: 8px; }.demo-box { margin-top: 20px; padding: 15px; background-color: white; border: 1px solid #ddd; border-radius: 4px; }</style>",
  "vue": "<template><div class=\"vue-demo\"><h1>{{ title }}</h1><p>{{ message }}</p><button @click=\"changeMessage\">点击改变消息</button></div></template><script setup>import { ref } from \"vue\"; const title = ref(\"Vue 组件演示\"); const message = ref(\"这是来自Vue组件的内容\"); const changeMessage = () => { message.value = \"消息已更改\"; };</script><style scoped>.vue-demo { padding: 20px; border: 1px solid #ccc; border-radius: 8px; }</style>",
  "chart": "<div id=\"chart\" style=\"width: 100%; height: 400px;\">图表容器</div>"
}